{
  "appId": "com.pata.careon-gym",
  "files": ["dist-electron", "dist-react"],

  "mac": {
    "target": "dmg",
    "icon": "build/icon.icns"
  },

  "linux": {
    "target": "AppImage",
    "category": "Utility",
    "icon": "build/icons"
  },

  "win": {
    "target": ["portable", "msi"],
    "icon": "build/icon.ico",
    "signAndEditExecutable": false
  },

  "extraResources": [
    {
      "from": "build",
      "to": "."
    }
  ]
}
