{
    "name": "admin",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "main": "./dist-electron/main.js",
    "scripts": {
        "dev": "vite --host",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "transpile:electron": "tsc --project electron/tsconfig.json",
        "electron:dev": "npm run transpile:electron && concurrently \"vite --host\" \"wait-on http://192.168.1.150:5173 && cross-env NODE_ENV=development electron .\"",
        "electron:build:win": "npm run transpile:electron && vite build && electron-builder --win --x64",
        "electron:build:mac": "npm run transpile:electron && vite build && electron-builder --mac --arm64",
        "electron:build:linux": "npm run transpile:electron && vite build && electron-builder --linux --x64"
    },
    "dependencies": {
        "@google/genai": "^1.40.0",
        "@tailwindcss/vite": "^4.1.18",
        "lucide-react": "^0.564.0",
        "qrcode.react": "^4.2.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "recharts": "^3.7.0",
        "tailwindcss": "^4.1.18"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@types/node": "^24.10.1",
        "@types/react": "^19.2.5",
        "@types/react-dom": "^19.2.3",
        "@types/recharts": "^1.8.29",
        "@vitejs/plugin-react": "^5.1.1",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "electron": "^41.1.1",
        "electron-builder": "^26.8.1",
        "eslint": "^9.39.1",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.24",
        "globals": "^16.5.0",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.46.4",
        "vite": "^7.2.4",
        "vite-plugin-electron": "^0.29.1",
        "wait-on": "^9.0.4"
    }
}
